"    <li>Ancient monuments and historic buildings</li>\n"
"    <li>Culture</li>\n"
"    <li>Economic development</li>\n"
"    <li>Education and training</li>\n"
"    <li>Environment</li>\n"
"    <li>Fire and rescue services and promotion of fire safety</li>\n"
"    <li>Food</li>\n"
"    <li>Health and health services</li>\n"
"    <li>Highways and transport</li>\n"
"    <li>Housing</li>\n"
"    <li>Local government</li>\n"
"    <li>Public administration</li>\n"
"    <li>Social welfare</li>\n"
